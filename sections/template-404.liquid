<div class="max-w-md">
    <div class="text-5xl font-bold my-4">{{ section.settings.title }}</div>
    <div class="my-4"><p class="text-base md:text-xl leading-normal">{{ section.settings.sub_text }} </p></div>
    <div class="my-4"><a href="{{ section.settings.button_url | default : shop.secure_url }}" class="px-4 inline py-2 text—base font-medium shadow bg-green-600 hover:bg-green-800 text-white">{{ section.settings.button_label }}</a></div>
</div>
 
{% schema %}
{
    "name" : "Template 404",
    "tag" : "section",
    "class" :  "flex items-center justify-center text-center py-7 h-screen",
    "settings" : [
        {
            "type" : "text",
            "id" : "title",
            "label" : "404 Heading Title",
            "default" : "404"
        },
        {
            "type" : "text", 
            "id" : "sub_text",
            "label" : "404 Sub Text",
            "default" : "The Page that you are looking for is not found"
        },
        {
            "type" : "text",
            "id" : "button_label",
            "label" : "Button Text",
            "default" : "Go to Homepage"
        },
        {
            "type" : "url",
            "id" : "button_url",
            "label" : "Button URL",
        }
    ]
}

{% endschema %}